# ---- Bitcoin / market data ----
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
MEMPOOL_API_BASE=https://mempool.space/api

# ---- EirGrid Smart Grid Dashboard ----
EIRGRID_API_BASE=https://www.smartgriddashboard.com/DashboardService.svc/data

# ---- Make.com social webhook ----
MAKE_SOCIAL_WEBHOOK_SECRET=

# ---- Analytics (cookieless Plausible/Umami) ----
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# ---- App ----
NEXT_PUBLIC_SITE_URL=https://irishgrid.com
DEFAULT_LOCALE=en
