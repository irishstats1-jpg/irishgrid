# ---- Supabase (Postgres + Auth) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- OpenAI (blog drafting + GA translation) ----
OPENAI_API_KEY=

# ---- Resend (contact / pledge / submission email) ----
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=

# ---- Maps (only if using Mapbox; default build uses OSM/SVG, no token needed) ----
