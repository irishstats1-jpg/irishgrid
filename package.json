{
  "name": "irish-grid",
  "version": "0.1.0",
  "private": true,
  "description": "Irish Grid — an independent, data-driven advocacy site about the Republic of Ireland's electricity grid, curtailment waste, and flexible Bitcoin-mining load. Not affiliated with EirGrid or SONI.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "next": "^15.5.20",
    "next-intl": "^3.26.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/leaflet": "^1.9.20",
    "@types/node": "20.14.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "^15.5.20",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3",
    "vitest": "2.0.4",
    "wrangler": "^4.106.0"
  }
}
